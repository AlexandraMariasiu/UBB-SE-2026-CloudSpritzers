<UserControl
    x:Class="CloudSpritzers1.src.view.general.UpperBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    VerticalAlignment="Top">

    <Grid Background="White" 
      Padding="20,5" 
      Height="70" 
      BorderBrush="#E0E0E0" 
      BorderThickness="0,0,0,1">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="ms-appx:///Assets/CloudSpritzersLogo.png" Width="70" Height="70"/>
            <TextBlock Text="CloudSpritzers" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#001B3D"
                   Margin="10,0,0,0" 
                   VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="30">
            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="#001B3D">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BD;" FontSize="16"/>
                    <TextBlock Text="Chat" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="#001B3D">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE11B;" FontSize="16"/>
                    <TextBlock Text="FAQ" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="#001B3D">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8A1;" FontSize="16"/>
                    <TextBlock Text="Tickets" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="#001B3D">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE734;" FontSize="16"/>
                    <TextBlock Text="Reviews" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Button Grid.Column="4" 
            Padding="5"
            Style="{StaticResource TextBlockButtonStyle}" 
            VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid HorizontalAlignment="Center" Margin="0,0,0,2">
                    <Ellipse Width="34" Height="34" Fill="#F2F2F2"/>
                    <FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="#001B3D"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding UserId}"
                       FontSize="9" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>