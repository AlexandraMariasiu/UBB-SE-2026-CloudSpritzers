<Page
    x:Class="CloudSpritzers1.src.view.general.LandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:CloudSpritzers1.src.dto"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="50">
            
            <Grid Height="500">
                <FlipView x:Name="SupportCarousel" Background="Black"
                          IsHitTestVisible="False"
                          UseTouchAnimationsForAllNavigation="False">
                    <FlipViewItem>
                        <Grid>
                            <Image Source="/Assets/Support1.jpg" Stretch="UniformToFill" Opacity="0.7"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Premium Customer Support" FontSize="48" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                                <TextBlock Text="Available 24/7 for all your travel needs" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </FlipViewItem>
                    
                    <FlipViewItem>
                        <Grid>
                            <Image Source="/Assets/Airport2.jpg" Stretch="UniformToFill" Opacity="0.7"/>
                            <TextBlock Text="Seamless Airport Assistance" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48" FontWeight="Bold" Foreground="White"/>
                        </Grid>
                    </FlipViewItem>

                    <FlipViewItem>
                        <Grid>
                            <Image Source="/Assets/Travel3.jpg" Stretch="UniformToFill" Opacity="0.7"/>
                            <TextBlock Text="Global Coverage" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48" FontWeight="Bold" Foreground="White"/>
                        </Grid>
                    </FlipViewItem>
                </FlipView>

                </Grid>

            <StackPanel Spacing="20" Margin="40,0,40,40">
                <TextBlock Text="What Our Customers Say" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>

                <ItemsControl ItemsSource="{x:Bind ViewModel.Reviews}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" HorizontalAlignment="Center" ItemWidth="400" MaximumRowsOrColumns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:ReviewDTO">
                            <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}" 
                                    Margin="10" Padding="24" CornerRadius="12" 
                                    BorderThickness="1" BorderBrush="#E0E0E0">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="⭐⭐⭐⭐⭐" Foreground="Teal" FontSize="18"/>

                                    <TextBlock Text="{x:Bind message}" TextWrapping="Wrap" FontStyle="Italic" FontSize="16"/>

                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="{x:Bind userName}" FontWeight="Bold"/>
                                        <TextBlock Text="Verified Traveler" FontSize="12" Opacity="0.6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>