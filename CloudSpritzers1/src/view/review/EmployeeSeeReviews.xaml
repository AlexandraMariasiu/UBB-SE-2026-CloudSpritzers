<Page
    x:Class="CloudSpritzers1.src.view.review.EmployeeSeeReviews"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CloudSpritzers1.src.view.review"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="White">

    <Page.Resources>
        <Style x:Key="ReviewCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="0">

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Customer Reviews" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="#0F172A"/>
                <TextBlock Text="View customer feedback and ratings (Read-only)" 
                           Foreground="#64748B" 
                           FontSize="16"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Border Style="{StaticResource ReviewCardStyle}">
                <StackPanel Spacing="24">
                    <TextBlock Text="Overall Statistics" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#1E293B"/>

                    <Grid ColumnDefinitions="*, *, *, *, *">
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Total Reviews" Foreground="#64748B" FontSize="14"/>
                            <TextBlock Text="5" Foreground="#06B6D4" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Duty Free Shops" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <RatingControl Value="3.8" IsReadOnly="True" RequestedTheme="Light"/>
                            <TextBlock Text="3.8" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Flight Experience" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <RatingControl Value="4.2" IsReadOnly="True" RequestedTheme="Light"/>
                            <TextBlock Text="4.2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Staff Friendliness" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <RatingControl Value="4.4" IsReadOnly="True" RequestedTheme="Light"/>
                            <TextBlock Text="4.4" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Cleanliness" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <RatingControl Value="4.2" IsReadOnly="True" RequestedTheme="Light"/>
                            <TextBlock Text="4.2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ReviewCardStyle}">
                <Grid RowDefinitions="Auto, Auto, Auto">

                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Grid Width="48" Height="48">
                            <Ellipse Fill="#06B6D4"/>
                            <TextBlock Text="JS" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Foreground="White" 
                                       FontWeight="Bold"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Text="John Smith" FontWeight="Bold" FontSize="18" Foreground="#1E293B"/>
                            <TextBlock Text="2026-03-18 15:30" Foreground="#94A3B8" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="Overall Rating" FontSize="12" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                            <RatingControl Value="4.5" IsReadOnly="True" RequestedTheme="Light"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*, *, *, *" Margin="0,24">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Duty Free Shops" FontSize="12" Foreground="#64748B"/>
                            <RatingControl Value="5" IsReadOnly="True" RequestedTheme="Light" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Flight Experience" FontSize="12" Foreground="#64748B"/>
                            <RatingControl Value="4" IsReadOnly="True" RequestedTheme="Light"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Staff Friendliness" FontSize="12" Foreground="#64748B"/>
                            <RatingControl Value="5" IsReadOnly="True" RequestedTheme="Light"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock Text="Cleanliness" FontSize="12" Foreground="#64748B"/>
                            <RatingControl Value="4" IsReadOnly="True" RequestedTheme="Light"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="8" Padding="16">
                        <TextBlock Text="&quot;Great experience overall! The staff was very friendly and helpful. Flight was smooth and comfortable.&quot;" 
                                   FontStyle="Italic" 
                                   Foreground="#334155" 
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>