<Page
    x:Class="CloudSpritzers1.src.view.chat.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:msg="using:CloudSpritzers1.src.model.message"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:CloudSpritzers1.src.view.message"
    xmlns:dto="using:CloudSpritzers1.src.dto"
    xmlns:local="using:CloudSpritzers1.src.view.chat"
    xmlns:bot="using:CloudSpritzers1.src.model.faq.bot"
    x:Name="RootPage"
    mc:Ignorable="d"
    Background="White"
    
    >

	<Grid Padding="20">

		<!-- ROWS -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Grid Width="40" Height="40">
				<Ellipse Fill="#3AB0B0"/>
				<FontIcon Glyph="&#xE8BD;"
                          Foreground="White"
                          FontSize="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                
			</Grid>

            <StackPanel Grid.Column="1"
            Margin="15,0,0,0"
            VerticalAlignment="Center">

                <TextBlock Text="Chat Support"
               Foreground="#001B3D" 
               FontSize="18"
               FontWeight="SemiBold"/>

                <TextBlock Text="User ID: e"
               Foreground="#666666" 
               FontSize="12"/>
            </StackPanel>

            <HyperlinkButton Grid.Column="2"
                             Content="End Chat &amp; Rate"
                             Foreground="#3AB0B0"
                             VerticalAlignment="Center"/>
		</Grid>

		<!-- SEPARATOR -->
		<Border Grid.Row="0"
                Height="1"
                Background="#F0F0F0"
                VerticalAlignment="Bottom"
                Margin="-20,10,-20,0"/>

		<!-- CHAT AREA -->
        <ListView Grid.Row="1" 
          ItemsSource="{x:Bind ViewModel.ChatHistory, Mode=OneWay}"
          SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="dto:MessageDTO">
                    <view:MessageView Margin="0,5" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- OPTIONS -->
        <StackPanel Grid.Row="2"
            Spacing="10"
            Margin="0,10,0,10">

            <TextBlock Text="Please select an option:"
               Foreground="white"
               FontSize="13"/>

            <StackPanel Orientation="Horizontal"
                Spacing="8">

                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3AB0B0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter x:Name="ContentPresenter"
                                Background="{TemplateBinding Background}"
                                Foreground="{TemplateBinding Foreground}"
                                Content="{TemplateBinding Content}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="#2E8E8E" Duration="0:0:0.1"/>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                To="White" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Pressed">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="#1F6363" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </ContentPresenter>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>

                <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="bot:FAQOption">
                            <Button Content="{x:Bind Label}" 
                    Margin="4"
                    Command="{Binding ElementName=RootPage, Path=ViewModel.HandleOptionClickCommand}"
                    CommandParameter="{x:Bind}">
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </StackPanel>

    </Grid>

</Page>