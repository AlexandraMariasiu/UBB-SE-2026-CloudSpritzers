<Page
    x:Class="CloudSpritzers1.src.view.chat.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:CloudSpritzers1.src.view.chat"
    mc:Ignorable="d"
    Background="White"
    
    >

	<Grid Padding="20">

		<!-- ROWS -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
		<Grid Grid.Row="0" Margin="0,0,0,20">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Grid Width="40" Height="40">
				<Ellipse Fill="#3AB0B0"/>
				<FontIcon Glyph="&#xE8BD;"
                          Foreground="White"
                          FontSize="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
			</Grid>

			<StackPanel Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center">

				<TextBlock Text="Live Support"
                           FontSize="18"
                           FontWeight="SemiBold"/>

				<TextBlock Text="User ID: e"
                           Foreground="Gray"
                           FontSize="12"/>
			</StackPanel>

			<HyperlinkButton Grid.Column="2"
                             Content="End Chat &amp; Rate"
                             Foreground="#3AB0B0"
                             VerticalAlignment="Center"/>
		</Grid>

		<!-- SEPARATOR -->
		<Border Grid.Row="0"
                Height="1"
                Background="#F0F0F0"
                VerticalAlignment="Bottom"
                Margin="-20,10,-20,0"/>

		<!-- CHAT AREA -->
		<ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,20">

			<StackPanel Spacing="10">

				<Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Left"
                        MaxWidth="400"
                        Padding="15,10">

					<StackPanel>

						<TextBlock
                            Text="Hello! Welcome to CloudSpritzers support. How can I help you today?"
                            TextWrapping="Wrap"
                            FontSize="14"/>

						<TextBlock Text="09:55 PM"
                                   FontSize="10"
                                   Foreground="Gray"
                                   Margin="0,5,0,0"/>

					</StackPanel>

				</Border>

			</StackPanel>

		</ScrollViewer>

		<!-- OPTIONS -->
        <StackPanel Grid.Row="2"
            Spacing="10"
            Margin="0,10,0,10">

            <TextBlock Text="Please select an option:"
               Foreground="Gray"
               FontSize="13"/>

            <StackPanel Orientation="Horizontal"
                Spacing="8">

                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3AB0B0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter x:Name="ContentPresenter"
                                Background="{TemplateBinding Background}"
                                Foreground="{TemplateBinding Foreground}"
                                Content="{TemplateBinding Content}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="#2E8E8E" Duration="0:0:0.1"/>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                To="White" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Pressed">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="#1F6363" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </ContentPresenter>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>

                <Button Content="Flight Information"/>
                <Button Content="Baggage Issue"/>
                <Button Content="Refund Request"/>
                <Button Content="Other Issue"/>

            </StackPanel>
        </StackPanel>

    </Grid>

</Page>