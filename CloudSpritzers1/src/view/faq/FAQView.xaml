                                                            <TextBlock Text="{Binding Question}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#2AA9C9"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <FontIcon Glyph="&#xE8A7;" FontSize="11" Foreground="#6B7280"/>
                                                                    <TextBlock Text="{Binding ViewCount}" FontSize="11" Foreground="#6B7280"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <FontIcon Grid.Column="1" Glyph="{Binding IsExpanded, Converter={StaticResource BooleanToGlyphConverter}}" Foreground="#6B7280" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Button>
                                    <Button x:Name="SelectedFaqHeaderButton"
                                    Style="{StaticResource FaqAccordionHeaderButtonStyle}"
                                    Click="SelectedFaqHeaderButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="SelectedQuestionText"
                                                   Text="What facilities are available at the airport?"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   TextWrapping="Wrap"/>

                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock x:Name="SelectedCategoryText"
                                                       Text="Airport Facilities &amp; Services"
                                                       FontSize="11"
                                                       Foreground="#2AA9C9"/>

                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE8A7;"
                                                          FontSize="11"
                                                          Foreground="#6B7280"/>
                                                        <TextBlock x:Name="SelectedViewsText"
                                                           Text="1234 views"
                                                           FontSize="11"
                                                           Foreground="#6B7280"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <FontIcon x:Name="SelectedFaqChevron"
                                              Grid.Column="1"
                                              Glyph="&#xE76C;"
                                              Foreground="#6B7280"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0"/>

                                        </Grid>
                                    </Button>

                                                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" Spacing="12">
                                                    <TextBlock Text="{Binding Answer}" TextWrapping="Wrap" FontSize="13" Foreground="#374151" LineHeight="22"/>

                                                    <StackPanel Spacing="8" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Feedback summary" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                                            <TextBlock FontSize="12" Foreground="#15803D"><Run Text="Helpful: "/><Run Text="{Binding WasHelpfulVotes}"/></TextBlock>
                                                            <TextBlock FontSize="12" Foreground="#B42318"><Run Text="Not helpful: "/><Run Text="{Binding WasNotHelpfulVotes}"/></TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Spacing="12" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Was this answer helpful?" FontSize="12" Foreground="#4B5563" Visibility="{Binding HasFeedback, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{Binding HasFeedback, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                            <Button Click="HelpfulButton_Click" Tag="{Binding}" CornerRadius="8" Padding="12,8" Style="{StaticResource CategoryButtonStyle}">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <FontIcon Glyph="&#xE00B;" FontSize="12"/>
                                                                    <TextBlock Text="Yes" FontSize="12"/>
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Click="NotHelpfulButton_Click" Tag="{Binding}" CornerRadius="8" Padding="12,8" Style="{StaticResource CategoryButtonStyle}">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <FontIcon Glyph="&#xE00C;" FontSize="12"/>
                                                                    <TextBlock Text="No" FontSize="12"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                        <TextBlock Text="Thank you for your feedback!" FontSize="12" Foreground="#6B7280" Visibility="{Binding HasFeedback, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
