<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CloudSpritzers1.src.view.faq.FAQView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CloudSpritzers1.src.view.faq"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:general="using:CloudSpritzers1.src.view.general"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:CloudSpritzers1.src.dto"
    mc:Ignorable="d"
    Background="White">

    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:BooleanToGlyphConverter x:Key="BooleanToGlyphConverter"/>
        <local:HelpfulBackgroundConverter x:Key="HelpfulBackgroundConverter"/>
        <local:HelpfulForegroundConverter x:Key="HelpfulForegroundConverter"/>
        <local:HelpfulBorderConverter x:Key="HelpfulBorderConverter"/>
        <local:NotHelpfulBackgroundConverter x:Key="NotHelpfulBackgroundConverter"/>
        <local:NotHelpfulForegroundConverter x:Key="NotHelpfulForegroundConverter"/>
        <local:NotHelpfulBorderConverter x:Key="NotHelpfulBorderConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EAEAEE"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SelectedCategoryButtonStyle" TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
            <Setter Property="Background" Value="#2CC7CF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PopularQuestionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#49C9D0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FaqAccordionHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <general:UpperBar Grid.Row="0" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="10">
                <Border MaxWidth="1050"
                        HorizontalAlignment="Center"
                        Background="White"
                        BorderBrush="#D8DDE3"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="0">
                    <StackPanel Spacing="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,16,0,0">
                            <TextBlock Text="Frequently Asked Questions" FontSize="22" FontWeight="SemiBold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                            <TextBlock Text="Find quick answers to common questions" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="#F8F8FA" BorderBrush="#E5E7EB" BorderThickness="0,1,0,1" Padding="10">
                            <StackPanel Spacing="10">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="AllQuestionsButton" Content="All Questions" Style="{StaticResource SelectedCategoryButtonStyle}" Click="AllQuestionsButton_Click"/>
                                        <Button Content="Check-in Procedures" Style="{StaticResource CategoryButtonStyle}" Click="CheckInButton_Click"/>
                                        <Button Content="Parking Information" Style="{StaticResource CategoryButtonStyle}" Click="ParkingButton_Click"/>
                                        <Button Content="Baggage Policies" Style="{StaticResource CategoryButtonStyle}" Click="BaggageButton_Click"/>
                                        <Button Content="Ticket Purchasing" Style="{StaticResource CategoryButtonStyle}" Click="TicketButton_Click"/>
                                        <Button Content="Airport Facilities &amp; Services" Style="{StaticResource CategoryButtonStyle}" Click="FacilitiesButton_Click"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel x:Name="EmployeeActionsPanel" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Visibility="Collapsed">
                                    <Button x:Name="AddFaqButton" Content="Add FAQ" Click="AddFaqButton_Click" Background="#2CC7CF" Foreground="White" CornerRadius="8"/>
                                    <Button x:Name="EditFaqButton" Content="Edit FAQ" Click="EditFaqButton_Click" Background="#E5E7EB" CornerRadius="8"/>
                                    <Button x:Name="DeleteFaqButton" Content="Delete FAQ" Click="DeleteFaqButton_Click" Background="#FDE2E2" Foreground="#B42318" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Padding="16">
                            <TextBlock Text="All Questions" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding FilteredFAQs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dto:FAQEntryDTO">
                                        <Border Margin="0,0,0,12" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel Spacing="10">
                                                <Button Click="AccordionHeader_Click" Style="{StaticResource FaqAccordionHeaderButtonStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="{Binding Question}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#2AA9C9"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <FontIcon Glyph="&#xE8A7;" FontSize="11" Foreground="#6B7280"/>
                                                                    <TextBlock Text="{Binding ViewCount}" FontSize="11" Foreground="#6B7280"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <FontIcon Grid.Column="1" Glyph="{Binding IsExpanded, Converter={StaticResource BooleanToGlyphConverter}}" Foreground="#6B7280" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Button>

                                                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" Spacing="12">
                                                    <TextBlock Text="{Binding Answer}" TextWrapping="Wrap" FontSize="13" Foreground="#374151" LineHeight="22"/>

                                                    <StackPanel Spacing="8" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Feedback summary" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                                            <TextBlock FontSize="12" Foreground="#15803D"><Run Text="Helpful: "/><Run Text="{Binding WasHelpfulVotes}"/></TextBlock>
                                                            <TextBlock FontSize="12" Foreground="#B42318"><Run Text="Not helpful: "/><Run Text="{Binding WasNotHelpfulVotes}"/></TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Spacing="12" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Was this answer helpful?" FontSize="12" Foreground="#4B5563" Visibility="{Binding HasFeedback, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{Binding HasFeedback, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                            <Button Click="HelpfulButton_Click" Tag="{Binding}" CornerRadius="8" Padding="12,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <FontIcon Glyph="&#xE00B;" FontSize="12"/>
                                                                    <TextBlock Text="Yes" FontSize="12"/>
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Click="NotHelpfulButton_Click" Tag="{Binding}" CornerRadius="8" Padding="12,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <FontIcon Glyph="&#xE00C;" FontSize="12"/>
                                                                    <TextBlock Text="No" FontSize="12"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                        <TextBlock Text="Thank you for your feedback!" FontSize="12" Foreground="#6B7280" Visibility="{Binding HasFeedback, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>