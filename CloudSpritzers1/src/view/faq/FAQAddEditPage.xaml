<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CloudSpritzers1.src.view.faq.FAQAddEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CloudSpritzers1.src.view.faq"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="#F5F5F5" Padding="24">
        <Border MaxWidth="700"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            BorderBrush="#D8DDE3"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">

           <StackPanel Spacing="18">

    <TextBlock Text="Add FAQ"
               FontSize="28"
               FontWeight="SemiBold"
               Foreground="#1F2937"/>

    <StackPanel Spacing="8">
        <TextBlock Text="Category"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#374151"/>
        <Border Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,2">
            <ComboBox x:Name="CategoryComboBox"
                      PlaceholderText="Select category"
                      MinWidth="300"
                      MinHeight="44"
                      Background="Transparent"
                      Foreground="#111827"
                      BorderThickness="0">
                <ComboBoxItem Content="CheckIn"/>
                <ComboBoxItem Content="Parking"/>
                <ComboBoxItem Content="Baggage"/>
                <ComboBoxItem Content="Tickets"/>
                <ComboBoxItem Content="Facilities"/>
            </ComboBox>
        </Border>
    </StackPanel>

    <StackPanel Spacing="8">
        <TextBlock Text="Question"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#374151"/>
        <Border Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,6">
            <TextBox x:Name="QuestionTextBox"
                     PlaceholderText="Enter the question"
                     TextWrapping="Wrap"
                     MinWidth="300"
                     MinHeight="44"
                     Background="Transparent"
                     Foreground="#111827"
                     BorderThickness="0"/>
        </Border>
    </StackPanel>

    <StackPanel Spacing="8">
        <TextBlock Text="Answer"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#374151"/>
        <Border Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,6">
            <TextBox x:Name="AnswerTextBox"
                     PlaceholderText="Enter the answer"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinWidth="300"
                     Height="140"
                     Background="Transparent"
                     Foreground="#111827"
                     BorderThickness="0"/>
        </Border>
    </StackPanel>

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,8,0,0">

        <Button x:Name="CancelButton"
                Content="Cancel"
                Click="CancelButton_Click"
                Background="#E5E7EB"
                Foreground="#111827"
                BorderThickness="0"
                CornerRadius="8"
                Padding="18,10"/>

        <Button x:Name="SaveButton"
                Content="Save Changes"
                Click="SaveButton_Click"
                Background="#2CC7CF"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="8"
                Padding="18,10"/>
    </StackPanel>

</StackPanel>
        </Border>
    </Grid>

</Page>
