<Page
    x:Class="CloudSpritzers1.src.view.ticket.TicketsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:CloudSpritzers1.src.dto"
    xmlns:general="using:CloudSpritzers1.src.view.general"
    RequestedTheme="Light"
    Background="{ThemeResource PageBackgroundBrush}"
    xmlns:ticket="using:CloudSpritzers1.src.model.ticket">

    <Page.Resources>
        <Style x:Key="TicketButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContentDialog x:Name="NewTicketDialog"
                       Title="Submit a New Ticket"
                       PrimaryButtonText="Send"
                       CloseButtonText="Cancel"
                       DefaultButton="Primary"
                       PrimaryButtonClick="NewTicketDialog_PrimaryButtonClick">
            <StackPanel Spacing="12" Width="400">
                <TextBox Header="Title of the issue*" 
                         PlaceholderText="e.g. Damaged suitcase"
                         Text="{x:Bind ViewModel.NewTicketTitle, Mode=TwoWay}"/>

                <ComboBox Header="Category*" 
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.Categories}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="ticket:TicketCategory">
                            <TextBlock Text="{x:Bind CategoryName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ComboBox Header="Subcategory*" 
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.Subcategories}"
                          SelectedItem="{x:Bind ViewModel.SelectedSubcategory, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="ticket:TicketSubcategory">
                            <TextBlock Text="{x:Bind SubcategoryName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox Header="Description*" 
                         PlaceholderText="Details..." 
                         Height="120" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         Text="{x:Bind ViewModel.NewTicketDescription, Mode=TwoWay}"/>
            </StackPanel>
        </ContentDialog>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <general:UpperBar Grid.Row="0" />

        <Grid Grid.Row="1" Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="60" Height="60" CornerRadius="8" Background="{ThemeResource PrimaryBrush}">
                            <SymbolIcon Symbol="Tag" Foreground="White"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Support Tickets" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Width="600" TextWrapping="Wrap" Text="Submit and track your support requests." Foreground="{ThemeResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="CreateTicketButton" Content="Create new ticket" Width="180" Height="40"
                            Style="{StaticResource TicketButtonStyle}" Click="CreateTicketButton_Click"/>

                    <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8" Padding="32" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tickets" FontSize="24" FontWeight="SemiBold"/>
                                <ComboBox Grid.Column="1" Width="180" PlaceholderText="Filter tickets" SelectionChanged="FilterChanged" SelectedIndex="0">
                                    <ComboBoxItem Content="All Tickets" Tag="ALL"/>
                                    <ComboBoxItem Content="Open" Tag="OPEN"/>
                                    <ComboBoxItem Content="In Progress" Tag="IN_PROGRESS"/>
                                    <ComboBoxItem Content="Resolved" Tag="RESOLVED"/>
                                </ComboBox>
                            </Grid>

                            <ItemsControl Grid.Row="1" Margin="0,24,0,0" ItemsSource="{x:Bind ViewModel.FilteredTicketsForDisplay, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dto:TicketDTO">
                                        <Border BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{x:Bind Subject}" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{x:Bind CurrentStatus}" FontSize="12" Foreground="Blue"/>
                                                    <TextBlock Text="{x:Bind CreationTimestamp}" FontSize="12" Foreground="Gray"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>