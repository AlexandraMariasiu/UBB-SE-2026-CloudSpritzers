<?xml version="1.0" encoding="utf-8"?>
<Page
   x:Class="CloudSpritzers1.src.view.ticket.TicketEmployeeView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:controls="using:Microsoft.UI.Xaml.Controls" 
   xmlns:ticket="using:CloudSpritzers1.src.model.ticket"
   xmlns:general="using:CloudSpritzers1.src.view.general"
   xmlns:dto ="using:CloudSpritzers1.src.dto"
   RequestedTheme="Light"
   Background="#f9fafb">

    <!-- ================= BUTTON STYLE ================= -->
    <Page.Resources>
        <Style x:Key="TicketButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2bb8c0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2bb8c0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#25a5ac"
                                                        Duration="0:0:0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#1e8a90"
                                                        Duration="0:0:0"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <general:UpperBar Grid.Row="0" />

        <!-- ================= PAGE LAYOUT ================= -->
        <Grid Grid.Row="1" Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="60" Height="60" CornerRadius="8" Background="#2bb8c0">
                            <SymbolIcon Symbol="Repair" Foreground="White" RenderTransformOrigin="0.5,0.5">
                                <SymbolIcon.RenderTransform>
                                    <ScaleTransform ScaleX="2" ScaleY="2"/>
                                </SymbolIcon.RenderTransform>
                            </SymbolIcon>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Support Tickets" FontSize="28" FontWeight="SemiBold" Foreground="Black"/>
                            <TextBlock Width="600" TextWrapping="Wrap" Foreground="#6b7280"
                               Text="Resolve the requests of our customers."/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="White" CornerRadius="8" Padding="32" BorderBrush="#e5e7eb" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Vertical" Spacing="4">
                                <TextBlock Text="Tickets" FontSize="28" FontWeight="SemiBold" Foreground="Black"/>
                                <TextBlock Text="Change the status of submitted tickets." FontSize="14" Foreground="#6b7280"/>
                            </StackPanel>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <SymbolIcon Symbol="Filter" Foreground="#6b7280" Margin="0,0,8,0"/>
                                    <ComboBox Width="180" Background="#f3f4f6" SelectedIndex="0" SelectionChanged="FilterChanged">
                                        <ComboBoxItem Content="All Tickets" Tag="All"/>
                                        <ComboBoxItem Content="Open" Tag="Open"/>
                                        <ComboBoxItem Content="In Progress" Tag="InProgress"/>
                                        <ComboBoxItem Content="Resolved" Tag="Resolved"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <ItemsControl Grid.Row="1" x:Name="TicketList" ItemsSource="{x:Bind ViewModel.TicketsRead, Mode=OneWay}" Margin="0,24,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dto:TicketDTO">
                                        <Border Background="White" 
                    BorderBrush="#e5e7eb" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="20" 
                    Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{x:Bind TicketId}" FontSize="12" Foreground="#6b7280"/>
                                                    <TextBlock Text="Lost Gold Suitcase" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                                    <TextBlock Text="My suitcase didn't arrive on flight RO123." Foreground="#4b5563" Margin="0,4,0,8"/>

                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding CategoryName, ConverterParameter='Category: {0}', Mode=OneWay}" FontSize="12" Foreground="#6b7280"/>
                                                        <TextBlock Text="|" Foreground="#e5e7eb"/>
                                                        <TextBlock Text="{x:Bind SubcategoryName}" FontSize="12" Foreground="#6b7280"/>
                                                        <TextBlock Text="|" Foreground="#e5e7eb"/>
                                                        <TextBlock Text="Created: 03.04.2026" FontSize="12" Foreground="#6b7280"/>
                                                        <TextBlock Text="|" Foreground="#e5e7eb"/>
                                                        <TextBlock Text="{x:Bind UserEmail}" FontSize="12" Foreground="#6b7280"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Spacing="8">
                                                    <Border Background="#eef2ff" Padding="8,4" CornerRadius="4">
                                                        <TextBlock Text="{x:Bind Status}" Foreground="#4f46e5" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Border Background="#fef2f2" Padding="8,4" CornerRadius="4">
                                                        <TextBlock Text="{x:Bind UrgencyLevel}" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Button Content="Update Status" 
                                Click="EditTicketStatus_Click" 
                                Tag="{x:Bind TicketId}"
                                Style="{StaticResource TicketButtonStyle}"
                                Padding="12,4"
                                Margin="10,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#fff4e5" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Clock" Foreground="#ffb347" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Open" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                            <TextBlock Text="Awaiting review" FontSize="11" Foreground="#6b7280" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#e5f0ff" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Sync" Foreground="#5ca0ff" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="In Progress" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                            <TextBlock Text="Under investigation" FontSize="11" Foreground="#6b7280" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#e6ffed" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Accept" Foreground="#22c55e" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resolved" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                            <TextBlock Text="Issue closed" FontSize="11" Foreground="#6b7280" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>


